# Copy this file to .env and fill in the values you have.
# Everything is OPTIONAL - the system works fully with free data (yfinance)
# even if this file is empty.

# --- AI advisor (pick ONE or both; Gemini is used first if set) ---

# Google Gemini — for Gemini / Google AI Studio subscribers (recommended):
# Get key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# OpenAI — alternative:
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Optional market-data providers (not required, yfinance is used by default) ---
FINNHUB_API_KEY=
ALPHAVANTAGE_API_KEY=
